# Optional. The agent works without an LLM key by using deterministic local summaries.
NEWSLETTER_LLM_PROVIDER=auto

# Use Google Gemini (free tier) when set. Get a key at https://aistudio.google.com
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Use OpenAI when set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Or use local Ollama when OLLAMA_MODEL is set, for example:
# OLLAMA_MODEL=llama3.1

# Optional sender metadata used in the simulated email output.
NEWSLETTER_FROM=ai-newsletter-agent@example.com
NEWSLETTER_TO=subscribers@example.com
